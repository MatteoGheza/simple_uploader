<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex">
    <title>Caricamento file</title>
    <link href="https://releases.transloadit.com/uppy/v3.23.0/uppy.min.css" rel="stylesheet">
    <link rel="icon" type="image/png" href="/static/favicon-96x96.png?v=20260615" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg?v=20260615" />
    <link rel="shortcut icon" href="/static/favicon.ico?v=20260615" />
    <link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png?v=20260615" />
    <meta name="apple-mobile-web-app-title" content="Caricamento File" />
    <link rel="manifest" href="/static/site.webmanifest?v=20260615" />
    {% if isProd %}
    <script src="https://js-de.sentry-cdn.com/292595be9ace494a9faf16dacdec6dc4.min.js" crossorigin="anonymous"></script>
    <script>
    Sentry.onLoad(function() {
        Sentry.init({
            replaysSessionSampleRate: 0.1,
            replaysOnErrorSampleRate: 1.0
        });
    });
    </script>
    {% endif %}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    {% if isTurnstileEnabled %}<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>{% endif %}
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100dvh;
            margin: 0;
            background-color: #f4f7f6;
            padding: 10px;
        }
        .container {
            max-width: 650px;
            width: 100%;
            padding: 20px;
            text-align: center;
            background: white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border-radius: 8px;
            box-sizing: border-box;
            margin: auto 0;
        }
        h1 { color: #333; font-size: 1.5rem; }
        p { color: #666; margin-bottom: 20px; font-size: 1rem; }
        .user-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-width: 100%;
            margin: 0 auto;
        }
        .user-form input {
            padding: 12px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 1rem;
        }
        .user-form button {
            padding: 12px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
        }
        .user-form button:hover {
            background-color: #0056b3;
        }
        #turnstile-container {
            margin: 15px 0;
            display: flex;
            justify-content: center;
        }
        @media (max-width: 480px) {
            .container { padding: 15px; }
            h1 { font-size: 1.25rem; }
            p { font-size: 0.9rem; }
            .uppy-Dashboard-inner { height: 350px !important; }
        }
        .uppy-Dashboard-AddFiles { cursor: pointer; }
        #retry-container {
            margin-top: 15px;
            display: none;
        }
        #retry-button {
            padding: 10px;
            background-color: #f39c12;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        #description {
            text-align: left;
        }
        #turnstile-status-message {
            display:none;
            color:red;
            margin-bottom: 10px;
        }
        #upload-action-container {
            margin-top: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }
        #custom-upload-button {
            padding: 12px 24px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
            width: 100%;
        }
        #custom-upload-button:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }
        #upload-feedback {
            color: #666;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        {% if userName %}
            <div id="uploader-content">
                <h1>Ciao, {{ userName }}</h1>
                <p id="description">Seleziona foto o video da caricare.<br>Dimensione massima: 1GB per file.<br>Premi sul riquadro seguente per caricare i file.</p>
                <div id="drag-drop-area"></div>
                <div id="turnstile-status-message">Devi attendere che siano finiti i controlli di sicurezza.</div>
                <div id="upload-action-container">
                    <button id="custom-upload-button" class="no-file-selected">Premi per selezionare i file</button>
                    <div id="upload-feedback">Attendi il controllo di sicurezza per poter caricare.</div>
                </div>
                <div id="retry-container">
                    <button id="retry-button">Riprova il caricamento dei file falliti</button>
                </div>
                {% if isTurnstileEnabled %}
                <!-- Turnstile widget -->
                <div id="turnstile-container" class="cf-turnstile" data-sitekey="{{ siteKey }}" data-callback="onTurnstileSuccess"></div>
                {% endif %}
            </div>
        {% else %}
            <h1>Come ti chiami?</h1>
            <p>Inserisci il tuo Nome e Cognome per continuare.</p>
            <form action="/set-user" method="POST" class="user-form">
                <input type="text" name="name" placeholder="Nome e Cognome" required minlength="2">
                <button type="submit">Continua</button>
            </form>
        {% endif %}
    </div>

    {% if userName %}
    <script src="https://releases.transloadit.com/uppy/v3.23.0/uppy.min.js"></script>
    <script src="https://releases.transloadit.com/uppy/locales/v3.3.0/it_IT.min.js"></script>
    <script>
        const bytes = crypto.getRandomValues(new Uint8Array(8));
        const sessionId = Array.from(bytes, b =>
            b.toString(16).padStart(2, '0')
        ).join('');
        let isUploading = false;
        let uploadToken = null;

        const isTurnstileEnabled = {{ isTurnstileEnabled | json }};
        const customUploadButton = document.getElementById('custom-upload-button');
        const uploadFeedback = document.getElementById('upload-feedback');

        // Initialize button state
        if (!isTurnstileEnabled) {
            uploadFeedback.style.display = 'none';
        }

        async function onTurnstileSuccess(token) {
            const response = await fetch('/verify-turnstile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ 'cf-turnstile-response': token })
            });
            if (response.ok) {
                const data = await response.json();
                uploadToken = data.uploadToken;
                document.getElementById('turnstile-status-message').style.display = 'none';

                uploadFeedback.textContent = 'Ora puoi procedere con il caricamento.';
                customUploadButton.disabled = false;
            }
        }

        window.addEventListener('beforeunload', (event) => {
            if (isUploading) {
                event.preventDefault();
                event.returnValue = '';
            }
        });

        function isChromiumBasedAndroid() {
            return (
                /Android/i.test(navigator.userAgent) &&
                !!window.chrome &&
                typeof navigator.userAgentData !== "undefined"
            );
        }

        const allowedFileTypes = isChromiumBasedAndroid() ? undefined : ['image/*', 'video/*'];

        const uppy = new Uppy.Uppy({
            autoProceed: false,
            locale: Uppy.locales.it_IT,
            restrictions: {
                maxFileSize: 1073741824,
                allowedFileTypes
            },
            meta: {
                userName: '{{ userName }}',
                sessionId: sessionId,
                uploadToken: null // Will be updated
            }
        })
        .use(Uppy.Dashboard, {
            inline: true,
            target: '#drag-drop-area',
            showProgressDetails: true,
            proudlyDisplayPoweredByUppy: false,
            width: '100%',
            height: 400,
            note: 'Solo foto e video, fino a 1GB',
            browserBackButtonClose: true,
            hideRetryButton: true,
            hidePauseResumeButton: true,
            hideUploadButton: true
        })
        .use(Uppy.Tus, {
            endpoint: '/upload',
            chunkSize: 83886080,
            retryDelays: [0, 1000]
        });

        // Trigger upload on custom button click
        customUploadButton.addEventListener('click', () => {
            if (customUploadButton.classList.contains('no-file-selected')) {
                const dashboard = document.querySelector('.uppy-Dashboard-AddFiles');
                if (dashboard) {
                    const fileInput = document.querySelector('.uppy-Dashboard-input');
                    if (fileInput) { fileInput.click(); }
                }
                return;
            }
            customUploadButton.disabled = true;
            uppy.upload();
        });

        document.addEventListener('click', (event) => {
            const dashboard = document.querySelector('.uppy-Dashboard-AddFiles');
            if (dashboard && dashboard.contains(event.target)) {
                const fileInput = document.querySelector('.uppy-Dashboard-input');
                if (fileInput) { fileInput.click(); }
            }
        });

        uppy.on('files-added', () => {
            customUploadButton.classList.remove('no-file-selected');
            customUploadButton.textContent = 'Carica file';
            if (isTurnstileEnabled && !uploadToken) {
                customUploadButton.disabled = true;
            } else {
                customUploadButton.disabled = false;
            }
        });

        uppy.on('file-removed', () => {
            if (uppy.getFiles().length === 0) {
                console.log('Nessun file selezionato, reset del pulsante di caricamento.');
                customUploadButton.classList.add('no-file-selected');
                customUploadButton.textContent = 'Premi per selezionare i file';
                customUploadButton.disabled = false;
            }
        });

        uppy.on('cancel-all', () => {
            console.log('Caricamento annullato, reset del pulsante di caricamento.');
            customUploadButton.classList.add('no-file-selected');
            customUploadButton.textContent = 'Premi per selezionare i file';
            customUploadButton.disabled = false;
        });

        uppy.on('upload-error', () => {
            isUploading = false;
        });

        uppy.on('upload', () => {
            if (isTurnstileEnabled && !uploadToken) {
                document.getElementById('turnstile-status-message').style.display = 'block';
                console.warn('Upload blocked: Turnstile verification required.');
                return;
            }
            document.getElementById('turnstile-status-message').style.display = 'none';
            uppy.setMeta({ uploadToken: uploadToken });
            isUploading = true;
        });

        uppy.on('complete', (result) => {
            isUploading = false;
            customUploadButton.disabled = false;
            
            // Toggle retry button visibility
            const retryContainer = document.getElementById('retry-container');
            if (result.failed.length > 0) {
                retryContainer.style.display = 'block';
            } else {
                retryContainer.style.display = 'none';
            }

            // Check if there are no failed files and some successful files
            if (result.failed.length === 0 && result.successful.length > 0) {
                Swal.fire({
                    title: 'Completato!',
                    text: 'Tutti i file sono stati caricati con successo.',
                    icon: 'success',
                    confirmButtonText: 'Ottimo'
                }).then(() => {
                    uppy.cancelAll();
                });
            } else if (result.failed.length > 0) {
                Swal.fire({
                    title: 'Attenzione',
                    text: `Alcuni file non sono stati caricati: ${result.failed.length} file.`,
                    icon: 'warning',
                    confirmButtonText: 'Chiudi'
                });
            }
        });

        document.getElementById('retry-button').addEventListener('click', () => {
            document.getElementById('retry-container').style.display = 'none';
            uppy.retryAll();
        });
    </script>
    {% endif %}
</body>
</html>
